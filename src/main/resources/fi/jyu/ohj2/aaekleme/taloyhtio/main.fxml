<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fi.jyu.ohj2.aaekleme.taloyhtio.MainController">
   <children>
      <TableView fx:id="asuntoTaulu" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="asuntoSarake" minWidth="-1.0" prefWidth="75.0" text="Asunto" />
          <TableColumn fx:id="asukasmaaraSarake" minWidth="-1.0" prefWidth="122.0" text="Asukkaiden määrä" />
        </columns>
         <VBox.margin>
            <Insets left="10.0" right="10.0" />
         </VBox.margin>
      </TableView>
      <HBox prefHeight="100.0" prefWidth="200.0">
         <children>
            <Button fx:id="lisaaAsuntoPainike" mnemonicParsing="false" text="Lisää asunto">
               <HBox.margin>
                  <Insets left="10.0" />
               </HBox.margin>
            </Button>
            <Button fx:id="muokkaaPainike" mnemonicParsing="false" text="Muokkaa">
               <HBox.margin>
                  <Insets left="10.0" right="10.0" />
               </HBox.margin>
            </Button>
            <Button fx:id="poistaPainike" mnemonicParsing="false" text="Poista" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets top="10.0" />
   </padding>
</VBox>
