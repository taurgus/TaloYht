<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fi.jyu.ohj2.aaekleme.taloyhtio.Controllers.AddAsukasController">

   <padding>
      <Insets top="10" right="10" bottom="10" left="10"/>
   </padding>
   <Label text="Lisää asukas" />

   <TextField fx:id="nimiKentta" promptText="Nimi"/>
   <TextField fx:id="syntymavuosiKentta" promptText="Syntymävuosi"/>
   <TextField fx:id="sahkopostiKentta" promptText="Sähköposti"/>

   <HBox spacing="10">
      <Button fx:id="tallennaPainike" text="Tallenna"/>
      <Button fx:id="suljePainike" text="Sulje"/>
   </HBox>

</VBox>